OPENAI_API_KEY=
# Optional OpenAI-compatible endpoint, e.g. https://api.openai.com/v1
OPENAI_BASE_URL=

# Optional model overrides
QUERY_GENERATOR_MODEL=gpt-4o-mini
REFLECTION_MODEL=gpt-4o-mini
ANSWER_MODEL=gpt-4o

# Prefer setting this key and letting app build Tavily MCP URL automatically
TAVILY_API_KEY=
